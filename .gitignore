# Node / Quartz / dashboard script
node_modules/
*.log
coverage/
.vitest-cache/
quartz/public/
quartz/.quartz-cache/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Obsidian
# Track .obsidian/community-plugins.json so a fresh clone knows which plugins to install.
# Ignore everything else: personal preferences, plugin binaries (re-installable),
# workspace/cache state (per-machine).
.obsidian/workspace*
.obsidian/cache
.obsidian/app.json
.obsidian/appearance.json
.obsidian/core-plugins.json
.obsidian/hotkeys.json
.obsidian/graph.json
.obsidian/plugins/
.obsidian/themes/
.obsidian/snippets/

# Secrets (belt & braces — shouldn't exist here anyway)
.env
.env.*
*.key
*.pem

# Session-local artifacts (not committed; used during development only)
.scratch/
.playwright-mcp/
.superpowers/
.tmp-ingest/

# Plugin skill caches
.agents/
.claude/skills/
skills-lock.json

# Slay the Cert — raw asset ZIPs staged for extraction (Session 4)
public/dungeon/public/assets/_dropzone/*.zip

# Git worktrees (isolated workspaces for feature branches)
.worktrees/

# Transient Claude Code scheduler lock
.claude/scheduled_tasks.lock

# Playwright MCP smoke-test artifacts (screenshots + session caches)
.playwright-mcp/
stc-*.png
