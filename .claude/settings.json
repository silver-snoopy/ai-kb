{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": ["-y", "obsidian-mcp", "C:/projects/ai-kb"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "WebFetch",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:anthropic.com)",
      "mcp__obsidian__*"
    ]
  }
}
